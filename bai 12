import pandas as pd
import numpy as np
import folium
import random
from math import sqrt


def distance(a, b):
    return sqrt((a[0]-b[0])**2 + (a[1]-b[1])**2)


np.random.seed(42)


warehouses = [
    (10.76, 106.68),
    (10.78, 106.66)
]


customers = [(10.75 + np.random.rand()*0.05, 106.65 + np.random.rand()*0.05) for _ in range(20)]


def nearest_route(start, points):
    route = [start]
    remaining = points.copy()
    current = start
    
    while remaining:
        next_point = min(remaining, key=lambda x: distance(current, x))
        route.append(next_point)
        remaining.remove(next_point)
        current = next_point
    
    return route


optimized_routes = []
for wh in warehouses:
    route = nearest_route(wh, customers.copy())
    optimized_routes.append(route)


random_routes = []
for wh in warehouses:
    rand_points = customers.copy()
    random.shuffle(rand_points)
    route = [wh] + rand_points
    random_routes.append(route)

m = folium.Map(location=[10.76, 106.68], zoom_start=13)


for wh in warehouses:
    folium.Marker(location=wh, icon=folium.Icon(color="blue"), popup="Warehouse").add_to(m)


for c in customers:
    folium.CircleMarker(location=c, radius=4, color="black", fill=True).add_to(m)


for route in optimized_routes:
    folium.PolyLine(route, color="green", weight=3).add_to(m)


for route in random_routes:
    folium.PolyLine(route, color="red", weight=1, dash_array="5,5").add_to(m)

m
