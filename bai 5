import folium
from geopy.distance import geodesic


center = (10.762622, 106.660172)

m = folium.Map(location=center, zoom_start=13)


folium.Marker(
    location=center,
    popup="Trung tâm UEH",
    icon=folium.Icon(color="red")
).add_to(m)


radii = [3, 5, 10]
colors = ["green", "orange", "blue"]


for r, color in zip(radii, colors):
    folium.Circle(
        location=center,
        radius=r * 1000,  # đổi km -> mét
        color=color,
        fill=True,
        fill_opacity=0.2,
        popup=f"Bán kính {r} km"
    ).add_to(m)


m
