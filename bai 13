import folium
import pandas as pd
import numpy as np


np.random.seed(42)


warehouses = [(10.76, 106.68), (10.78, 106.66)]


customers = [(10.75 + np.random.rand()*0.05, 106.65 + np.random.rand()*0.05) for _ in range(30)]


demand_points = pd.DataFrame({
    "lat": 10.75 + np.random.rand(50)*0.05,
    "lon": 106.65 + np.random.rand(50)*0.05,
    "demand": np.random.randint(10, 100, 50)
})


m = folium.Map(location=[10.76, 106.68], zoom_start=13)


warehouse_layer = folium.FeatureGroup(name="Warehouses")
for wh in warehouses:
    folium.Marker(location=wh, icon=folium.Icon(color="blue"), popup="Warehouse").add_to(warehouse_layer)


customer_layer = folium.FeatureGroup(name="Customers")
for c in customers:
    folium.CircleMarker(location=c, radius=4, color="black", fill=True).add_to(customer_layer)


demand_layer = folium.FeatureGroup(name="Demand")
def get_color(d):
    if d < 30:
        return "green"
    elif d < 70:
        return "orange"
    else:
        return "red"

for _, row in demand_points.iterrows():
    folium.CircleMarker(
        location=[row["lat"], row["lon"]],
        radius=5,
        color=get_color(row["demand"]),
        fill=True,
        fill_opacity=0.7,
        popup=f"Demand: {row['demand']}"
    ).add_to(demand_layer)

warehouse_layer.add_to(m)
customer_layer.add_to(m)
demand_layer.add_to(m)


folium.LayerControl().add_to(m)

m
